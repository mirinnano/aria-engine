; Core-mode init template for new projects
window 1280, 720, "ARIA Engine (Core Mode)"
compat_mode off
ui_theme "clean"
font "assets/fonts/NotoSansJP-Regular.ttf"
font_atlas_size 96
font_filter "bilinear"
script "assets/scripts/main.aria"
debug on

; Core mode text layout:
; 1) create textbox rect and text sprite in script
; 2) set target id by text_target
; 3) call text
textmode manual
text_target 3001
