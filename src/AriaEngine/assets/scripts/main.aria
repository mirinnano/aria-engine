if %0 == 2 { systemcall load }
if %0 == 2 { goto *return_title }
if %0 == 3 { settings_ui() }
if %0 == 3 { goto *return_title }
if %0 == 4 { omake_ui() }
if %0 == 4 { goto *return_title }
if %0 == 5 { end }
if %0 == 6 { goto *tester_info }
goto *title_loop

