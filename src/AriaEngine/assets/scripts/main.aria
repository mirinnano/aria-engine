# aria-version: 2.0
; 海風 -The Records of Autumn -
; ARIA v2 production title/chapter flow

compat_mode on
ui_theme "steel"
ui_quality "high"
ui_motion "smooth"
caption "海風 - The Records of Autumn -"
defaultspeed 24
textspeed 24
ui skip, speed, 3
ui skip, force_speed, 48
ui text, speed, 24
backlog on
kidokumode 1
skipmode read
clickcursor engine
system_button close, on
rmenu "SAVE",save,"LOAD",load,"BACKLOG",backlog,"SKIP",skip,"CONFIG",settings,"RESET",reset,"QUIT",end

#define CHAPTER_COUNT 6

goto *start

; ===========================================================
; ユーティリティ関数
; ===========================================================

func cls()
    textclear
    btndef clear
    csp -1
endfunc

func adv()
    textclear
    textfx reset
    textmode "adv"
    ; ADV: 黒鉄パネルで締める
    textbox 40, 540, 1200, 160
    fontsize 28
    textcolor "#e7e2d6"
    textbox_color "#0b0d10", 216
    textbox_style 8, 1, "#9aa18f", 116, 30, 22, 0, 6, "#000000", 150
endfunc

func nvl()
    textclear
    textfx reset
    textmode "nvl"
    textbox 72, 28, 1136, 628
    fontsize 34
    textcolor "#e7e2d6"
    textbox_color "#0b0d10", 178
    textbox_style 8, 1, "#9aa18f", 116, 36, 30, 0, 8, "#000000", 150
endfunc

func scenechange(path: string, dur: int)
    transition bg, $path, "fade", %dur
endfunc

func fadeout(dur: int)
    bg "#000000", %dur
endfunc

func fadein(path: string, dur: int)
    transition bg, $path, "fade", %dur
endfunc

func flash()
    screen flash, "#ffffff", 180
    sync fx
endfunc

func shake_light()
    camera shake, 3, 220
endfunc

func shake_strong()
    camera shake, 7, 360
endfunc

func text_effect(name: string)
    textfx $name, 1.2, 6
endfunc

func text_effect_off()
    textfx reset
endfunc

func text_speed_tmp(speed: int)
    textfx speed, %speed
endfunc

func text_speed_normal()
    textfx speed, 24
endfunc

func playse(path: string)
    dwave 0, $path
endfunc

func fx_reset()
    fx cancel, all
endfunc

func fx_profile_subtle()
    fx profile, "subtle"
    fx skip_policy, "finish"
endfunc

func fx_profile_intense()
    fx profile, "intense"
    fx skip_policy, "finish"
endfunc

func fx_scene_cut(path: string)
    screen tint, "#ffffff", 24, 90
    wait 60
    transition bg, $path, "fade", 520
endfunc

func fx_memory()
    screen tint, "#1d2430", 42, 1600
    wait 60
endfunc

func fx_shock()
    fx cancel, text
    screen tint, "#000000", 38, 90
    wait 60
    screen flash, "#ffffff", 70
    camera shake, 4, 190
    sync fx
    wait 70
endfunc

func fx_focus()
    fx cancel, text
    screen tint, "#000000", 36, 620
    wait 60
endfunc

func voice_line(path: string)
    voice $path
endfunc

func mood_calm()
    fx cancel, screen
    screen tint, "#101820", 24, 1200
endfunc

func mood_memory()
    screen tint, "#1d2430", 42, 1600
    wait 50
endfunc

func mood_danger()
    screen tint, "#2b0f12", 42, 1200
    wait 60
endfunc

func chapter_card_fx(title: string, sub: string)
    fx cancel, all
    screen tint, "#ffffff", 30, 110
    wait 70
    ui_rect 8700, 0, 0, 1280, 720
    ui sprite:8700, fill, "#050607"
    ui sprite:8700, fill_alpha, 232
    ui sprite:8700, opacity, 0
    ui sprite:8700, z, 9500
    ui_text 8701, $title, 640, 304
    ui sprite:8701, align, "center"
    ui sprite:8701, font_size, 34
    ui sprite:8701, color, "#e7e2d6"
    ui sprite:8701, opacity, 0
    ui sprite:8701, z, 9510
    ui_text 8702, $sub, 640, 360
    ui sprite:8702, align, "center"
    ui sprite:8702, font_size, 20
    ui sprite:8702, color, "#9aa18f"
    ui sprite:8702, opacity, 0
    ui sprite:8702, z, 9510
    ui_fade 8700, 255, 420
    ui_fade 8701, 255, 520
    ui_fade 8702, 255, 620
    ui_move 8701, 640, 292, 520
    ui_move 8702, 640, 346, 620
    wait 980
    ui_fade 8701, 0, 420
    ui_fade 8702, 0, 360
    wait 120
    ui_fade 8700, 0, 420
    wait 460
    csp 8700
    csp 8701
    csp 8702
endfunc

func choice_enter_fx()
    screen tint, "#000000", 28, 320
endfunc

func focus_fx()
    fx_focus()
endfunc

func card_mio()
    cls
    ui_rect 900, 0, 0, 1280, 720
    ui sprite:900, fill, "#050607"
    ui sprite:900, fill_alpha, 238
    ui sprite:900, opacity, 0
    ui sprite:900, z, 80
    ui_text 901, "MIO SIDE", 640, 308
    ui sprite:901, font_size, 22
    ui sprite:901, align, "center"
    ui sprite:901, color, "#9aa18f"
    ui sprite:901, opacity, 0
    ui sprite:901, z, 90
    ui_text 902, "―― ミオ 視点 ――", 640, 352
    ui sprite:902, font_size, 28
    ui sprite:902, align, "center"
    ui sprite:902, color, "#e7e2d6"
    ui sprite:902, text_shadow, 0, 3, "#000000"
    ui sprite:902, opacity, 0
    ui sprite:902, z, 90
    ui_fade 900, 255, 420
    ui_fade 901, 255, 520
    ui_fade 902, 255, 620
    ui_move 901, 640, 292, 540
    ui_move 902, 640, 336, 640
    wait 980
    ui_fade 901, 0, 360
    ui_fade 902, 0, 360
    wait 130
    ui_fade 900, 0, 420
    wait 460
    csp 900
    csp 901
    csp 902
    wait 120
endfunc

func card_ore()
    cls
    ui_rect 910, 0, 0, 1280, 720
    ui sprite:910, fill, "#050607"
    ui sprite:910, fill_alpha, 238
    ui sprite:910, opacity, 0
    ui sprite:910, z, 80
    ui_text 911, "HIS SIDE", 640, 308
    ui sprite:911, font_size, 22
    ui sprite:911, align, "center"
    ui sprite:911, color, "#b8a46f"
    ui sprite:911, opacity, 0
    ui sprite:911, z, 90
    ui_text 912, "―― 俺 視点 ――", 640, 352
    ui sprite:912, font_size, 28
    ui sprite:912, align, "center"
    ui sprite:912, color, "#e7e2d6"
    ui sprite:912, text_shadow, 0, 3, "#000000"
    ui sprite:912, opacity, 0
    ui sprite:912, z, 90
    ui_fade 910, 255, 420
    ui_fade 911, 255, 520
    ui_fade 912, 255, 620
    ui_move 911, 640, 292, 540
    ui_move 912, 640, 336, 640
    wait 980
    ui_fade 911, 0, 360
    ui_fade 912, 0, 360
    wait 130
    ui_fade 910, 0, 420
    wait 460
    csp 910
    csp 911
    csp 912
    wait 120
endfunc

