btndef clear
ui_button 30, 1
ui_button 31, 2
ui_button 32, 3
ui_button 33, 4
ui_button 34, 5
print 1

*title_loop
btnwait %0
if %0 == 1 { goto *start_continue }
if %0 == 2 { systemcall load }
if %0 == 2 { goto *title_loop }
    if %0 == 3 { settings_ui() }
    if %0 == 3 { goto *title_loop }
    if %0 == 4 { omake_ui() }
    if %0 == 4 { goto *title_loop }
if %0 == 5 { end }
goto *title_loop

*start_continue
if %10 == 1 { goto *chapter_select }
goto *scenario_01

