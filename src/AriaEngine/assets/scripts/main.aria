# aria-version: 2.0
; 海風 -The Records of Autumn -
; ARIA v2 production title/chapter flow

compat_mode on
ui_theme "steel"
ui_quality "high"
ui_motion "smooth"
caption "海風 - The Records of Autumn -"
defaultspeed 24
textspeed 24
ui skip, speed, 3
ui skip, force_speed, 48
ui text, speed, 24
backlog on
kidokumode 1
skipmode read
clickcursor engine
system_button close, on
rmenu "SAVE",save,"LOAD",load,"BACKLOG",backlog,"SKIP",skip,"CONFIG",settings,"RESET",reset,"QUIT",end

#define CHAPTER_COUNT 6

; ===========================================================
; ユーティリティ関数
; ===========================================================

func cls()
    textclear
    btndef clear
    csp -1
endfunc

func adv()
    textclear
    textmode "adv"
    ; ADV: 黒鉄パネルで締める
    textbox 40, 540, 1200, 160
    fontsize 28
    textcolor "#e7e2d6"
    textbox_color "#0b0d10", 216
    textbox_style 8, 1, "#9aa18f", 116, 30, 22, 0, 6, "#000000", 150
endfunc

func nvl()
    textclear
    textmode "nvl"
    textbox 72, 28, 1136, 628
    fontsize 34
    textcolor "#e7e2d6"
    textbox_color "#0b0d10", 178
    textbox_style 8, 1, "#9aa18f", 116, 36, 30, 0, 8, "#000000", 150
endfunc

func scenechange(path: string, dur: int)
    bg "#000000", %dur
    bg $path, %dur
endfunc

func fadeout(dur: int)
    bg "#000000", %dur
endfunc

func fadein(path: string, dur: int)
    bg $path, %dur
endfunc

func playse(path: string)
    dwave 0, $path
endfunc

func card_mio()
    cls
    ui_rect 900, 0, 0, 1280, 720
    ui sprite:900, fill, "#050607"
    ui sprite:900, fill_alpha, 238
    ui sprite:900, z, 80
    ui_text 901, "MIO SIDE", 640, 292
    ui sprite:901, font_size, 22
    ui sprite:901, align, "center"
    ui sprite:901, color, "#9aa18f"
    ui sprite:901, z, 90
    ui_text 902, "―― ミオ 視点 ――", 640, 336
    ui sprite:902, font_size, 28
    ui sprite:902, align, "center"
    ui sprite:902, color, "#e7e2d6"
    ui sprite:902, text_shadow, 0, 3, "#000000"
    ui sprite:902, z, 90
    wait 1200
    csp 900
    csp 901
    csp 902
    wait 250
endfunc

func card_ore()
    cls
    ui_rect 910, 0, 0, 1280, 720
    ui sprite:910, fill, "#050607"
    ui sprite:910, fill_alpha, 238
    ui sprite:910, z, 80
    ui_text 911, "HIS SIDE", 640, 292
    ui sprite:911, font_size, 22
    ui sprite:911, align, "center"
    ui sprite:911, color, "#b8a46f"
    ui sprite:911, z, 90
    ui_text 912, "―― 俺 視点 ――", 640, 336
    ui sprite:912, font_size, 28
    ui sprite:912, align, "center"
    ui sprite:912, color, "#e7e2d6"
    ui sprite:912, text_shadow, 0, 3, "#000000"
    ui sprite:912, z, 90
    wait 1200
    csp 910
    csp 911
    csp 912
    wait 250
endfunc

; ===========================================================
; エントリポイント
; ===========================================================

goto *start

include "ui_presets.aria"
include "settings_ui.aria"
include "gallery_ui.aria"
include "omake_ui.aria"
include "scenario_01.aria"
include "scenario_02.aria"
include "scenario_03.aria"
include "scenario_04.aria"
include "scenario_05.aria"
include "scenario_06.aria"

; 標準UI(save/load/backlog/rmenu)はC# MenuSystemに固定し、
; 作品固有画面だけスクリプトに委譲する。
ui menu_action, settings, *settings_ui
ui menu_action, gallery, *gallery_ui

; ===========================================================
