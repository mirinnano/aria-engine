window 1280, 720, "ARIA Engine - NScripter Import Test"
compat_mode on
font "assets/fonts/NotoSansJP-Regular.ttf"
font_atlas_size 96
font_filter "bilinear"
script "assets/scripts/00_converted.aria"
debug on

textbox 50, 500, 1180, 200
fontsize 32
textcolor "#ffffff"
textbox_color "#000000", 180
textbox_style 14, 1, "#ffffff", 70, 24, 20, 0, 3, "#000000", 90
choice_style 640, 56, 14, 30, "#111827", 220, "#f9fafb", 12, "#ffffff", 1, 60, "#1f2937", 20
